{
  "enabled": true,
  "name": "Pixel Agents: Prompt Start",
  "description": "Writes a user record to the Pixel Agents JSONL file when a new prompt is submitted.",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "bash .kiro/scripts/pixel-agents-bridge.sh init"
  }
}
