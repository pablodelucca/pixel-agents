{
  "enabled": true,
  "name": "Pixel Agents: Tool Done",
  "description": "Writes a tool_result record after each tool execution completes.",
  "version": "1",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "read",
      "write",
      "shell"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "bash .kiro/scripts/pixel-agents-bridge.sh tool-done"
  }
}
