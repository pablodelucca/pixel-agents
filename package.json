{
  "name": "clawmpany",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "kill:ports": "for port in 3000 3001 3002 3003 3004 3005 4000 4001 4002 4003 4004 4005 5173 5174 5175 5176; do lsof -ti :$port 2>/dev/null | xargs kill -9 2>/dev/null; done; true",
    "dev": "npm run kill:ports && sleep 0.5 && concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "start": "node server/dist/index.js",
    "dev:docker": "docker-compose up",
    "build:docker": "docker-compose build",
    "start:docker": "docker-compose up -d"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.18.0",
    "@supabase/supabase-js": "^2.103.0",
    "axios": "^1.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "lucide-react": "^0.577.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ssh2": "^1.16.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.4",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "jimp": "^1.6.0",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.2.4",
    "vite-plugin-node-polyfills": "^0.25.0"
  }
}
