{
  "name": "pixel-agents",
  "displayName": "Pixel Agents",
  "description": "Pixel art office where your Claude Code agents come to life as animated characters",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pablodelucca/pixel-agents"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all -p dev:server dev:client",
    "dev:server": "cd server && bun --watch index.ts",
    "dev:client": "cd webview-ui && npx vite",
    "build": "cd webview-ui && npm run build",
    "start": "cd server && bun index.ts",
    "install:all": "npm install && cd server && bun install && cd ../cli && bun install && cd ../webview-ui && npm install",
    "join": "cd cli && bun join.ts",
    "import-tileset": "bun scripts/import-tileset-cli.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/node": "22.x",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
