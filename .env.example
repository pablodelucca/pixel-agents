# ===========================================
# Frontend (Vite build-time)
# ===========================================
VITE_API_URL=http://localhost:5173
VITE_PRIVY_APP_ID=your_privy_app_id_here

# ===========================================
# Backend (Express runtime)
# ===========================================
PORT=3001

# Database (PocketBase — will be replaced with Supabase)
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=your_admin_password

# Frontend URL (for Tripay return_url & CORS)
FRONTEND_URL=http://localhost:5173

# Payment - USDC
PAYMENT_RECIPIENT_ADDRESS=0xYourWalletAddressHere

# Payment - Tripay
TRIPAY_API_KEY=your_tripay_api_key_here
TRIPAY_PRIVATE_KEY=your_tripay_private_key_here
TRIPAY_MERCHANT_CODE=your_tripay_merchant_code_here
TRIPAY_API_URL=https://tripay.co.id/api/transaction/create
